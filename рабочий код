# ================= NORMALIZE =================
def normalize_name(name: str):
    if not name:
        return ""
    return name.split("(")[0].strip().lower()

# ================= ANIME JSON =================
def get_anime_list():
    try:
        with open(JSON_PATH, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return []

# ================= GENRES =================
def get_genres():
    genres = set()
    for anime in get_anime_list():
        if "genre" in anime:
            for g in anime["genre"].split("/"):
                g = g.strip()
                if g:
                    genres.add(g)
    return sorted(genres)

# ================= PROFILE HELPERS =================
def ensure_user_profile(user_id: int):
    uid = str(user_id)
    found = db.search(User.user_id == uid)
    if found:
        return found[0]

    db.insert({
        "user_id": uid,
        "liked": [],
        "disliked": [],
        "last": None
    })
    return db.search(User.user_id == uid)[0]

def set_last_watched(user_id: int, anime_name: str):
    uid = str(user_id)
    ensure_user_profile(user_id)
    db.update({"last": anime_name}, User.user_id == uid)

def add_like(user_id: int, anime_name: str):
    uid = str(user_id)
    user = ensure_user_profile(user_id)

    liked = user.get("liked", [])
    disliked = user.get("disliked", [])

    if anime_name not in liked:
        liked.append(anime_name)
    if anime_name in disliked:
        disliked.remove(anime_name)

    db.update({"liked": liked, "disliked": disliked}, User.user_id == uid)

def add_dislike(user_id: int, anime_name: str):
    uid = str(user_id)
    user = ensure_user_profile(user_id)

    liked = user.get("liked", [])
    disliked = user.get("disliked", [])

    if anime_name not in disliked:
        disliked.append(anime_name)
    if anime_name in liked:
        liked.remove(anime_name)

    db.update({"liked": liked, "disliked": disliked}, User.user_id == uid)

def find_anime_index_by_normalized_name(normalized_name: str):
    for i, anime in enumerate(get_anime_list()):
        if normalize_name(anime.get("name", "")) == normalized_name:
            return i
    return None

def find_anime_index_by_exact_name(raw_name: str):
    target = normalize_name(raw_name)
    return find_anime_index_by_normalized_name(target)

