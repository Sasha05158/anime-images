# ================= INLINE SEARCH =================
async def inline_query(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.inline_query.query.lower().strip()
    results = []

    for i, anime in enumerate(get_anime_list()):
        name = anime.get("name", "")
        desc = anime.get("description", "")[:80]

        if not query or query in name.lower():
            results.append(
                InlineQueryResultArticle(
                    id=str(i),
                    title=name,
                    description=desc,
                    thumbnail_url=anime.get("image", ""),
                    input_message_content=InputTextMessageContent(
                        f"{name}\n\n{anime.get('description', '')}"
                    )
                )
            )

    await update.inline_query.answer(results[:20], cache_time=1)

# ================= SUB CHECK =================
async def check_subscription(user_id, context):
    try:
        member = await context.bot.get_chat_member(CHANNEL_USERNAME, user_id)
        return member.status in ["member", "administrator", "creator"]
    except Exception:
        return False

# ================= ANIME MENU =================
def anime_menu(idx, user_id=None):
    anime_list = get_anime_list()

    if idx is None or idx < 0 or idx >= len(anime_list):
        return "Помилка", None, None

    anime = anime_list[idx]
    name_raw = anime.get("name", "Без назви")
    name_norm = normalize_name(name_raw)

    results = db.search((User.anime == name_norm))
    votes = [r.get("rating") for r in results if isinstance(r.get("rating"), int)]
    avg = "немає оцінок" if not votes else f"{round(sum(votes) / len(votes), 1)} / 5 ⭐️"

    text = (
        f"{name_raw} ({anime.get('year', '?')})\n"
        f"Жанр: {anime.get('genre', '—')}\n"
        f"Рейтинг: {avg}\n\n"
        f"{anime.get('description', '')}"
    )

    keyboard = [
        [InlineKeyboardButton("🎬 Серії", callback_data=f"episodes_{idx}")],
        [InlineKeyboardButton("⭐️ Оцінити", callback_data=f"rate_{idx}")],
        [
            InlineKeyboardButton("❤️", callback_data=f"like_{idx}"),
            InlineKeyboardButton("💔", callback_data=f"dislike_{idx}")
        ],
        [InlineKeyboardButton("⬅️ Назад", callback_data="genres_back")]
    ]

    if user_id is not None:
        set_last_watched(user_id, name_norm)

    return text, InlineKeyboardMarkup(keyboard), anime.get("image")

# ================= SAFE MESSAGE FOR TEXT PAGES =================
async def replace_message(query, text, markup=None):
    try:
        await query.message.delete()
    except Exception:
        pass

    await query.message.reply_text(text, reply_markup=markup)

# ================= SAFE MESSAGE FOR PAGES WITH PHOTO =================
async def replace_keep_media(query, text, markup=None):
    try:
        if query.message.photo:
            await query.message.edit_caption(caption=text, reply_markup=markup)
        else:
            await query.message.edit_text(text=text, reply_markup=markup)
    except Exception:
        try:
            await query.message.delete()
        except Exception:
            pass
        await query.message.reply_text(text, reply_markup=markup)

# ================= SEND ANIME PAGE =================
async def send_anime_page(query, text, markup, photo, user_id=None):
    try:
        await query.message.delete()
    except Exception:
        pass

    if user_id is not None:
        anime_name = None
        try:
            idx = int(query.data.split("_")[1])
            anime_name = normalize_name(get_anime_list()[idx].get("name", ""))
        except Exception:
            anime_name = None
        if anime_name:
            set_last_watched(user_id, anime_name)

    if photo:
        await query.message.reply_photo(photo=photo, caption=text, reply_markup=markup)
    else:
        await query.message.reply_text(text, reply_markup=markup)

