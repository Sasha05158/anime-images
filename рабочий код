def build_profile_keyboard(user_id: int):
    user = ensure_user_profile(user_id)
    liked = user.get("liked", [])
    disliked = user.get("disliked", [])
    last = user.get("last")

    keyboard = []

    if last:
        idx = find_anime_index_by_normalized_name(last)
        if idx is not None:
            anime = get_anime_list()[idx]
            keyboard.append([InlineKeyboardButton(f"▶️ Останнє: {anime.get('name', last)}", callback_data=f"openanime_{idx}")])

    keyboard.append([InlineKeyboardButton("❤️ Подобається", callback_data="profile_liked")])
    keyboard.append([InlineKeyboardButton("💔 Не подобається", callback_data="profile_disliked")])
    keyboard.append([InlineKeyboardButton("⬅️ Меню", callback_data="profile_back")])

    text = (f"❤️ {len(liked)}   💔 {len(disliked)}")

    return text, InlineKeyboardMarkup(keyboard)

def build_profile_list_keyboard(names, empty_text="Пусто"):
    keyboard = []

    if not names:
        keyboard.append([InlineKeyboardButton(empty_text, callback_data="noop")])
    else:
        for norm_name in names:
            idx = find_anime_index_by_normalized_name(norm_name)
            if idx is None:
                continue
            anime = get_anime_list()[idx]
            keyboard.append([InlineKeyboardButton(anime.get("name", norm_name), callback_data=f"openanime_{idx}")])

    keyboard.append([InlineKeyboardButton("⬅️ Профіль", callback_data="profile_show")])
    return InlineKeyboardMarkup(keyboard)

# ================= CHAT =================
async def chat_logic(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global waiting_user

    user_id = update.effective_user.id
    text = update.message.text

    # ===== PROFILE =====
    if text == "📊 Профіль":
        profile_text, profile_markup = build_profile_keyboard(user_id)
        await update.message.reply_text(profile_text, reply_markup=profile_markup)

    # ===== FIND =====
    elif text == "💬 Знайти співрозмовника":

        if user_id in pairs:
            await update.message.reply_text(
                "Ви вже в чаті 😏",
                reply_markup=chat_keyboard_chat()
            )
            return

        if waiting_user == user_id:
            await update.message.reply_text(
                "Ти вже шукаєш 😏",
                reply_markup=chat_keyboard_search()
            )
            return

        if waiting_user is None:
            waiting_user = user_id
            await update.message.reply_text(
                "🔍 шукаю...",
                reply_markup=chat_keyboard_search()
            )
        else:
            partner = waiting_user

            if partner == user_id:
                await update.message.reply_text(
                    "Ти вже в черзі 😏",
                    reply_markup=chat_keyboard_search()
                )
                return

            waiting_user = None
            pairs[user_id] = partner
            pairs[partner] = user_id

            await context.bot.send_message(
                user_id,
                "💬 Знайдено 😏",
                reply_markup=chat_keyboard_chat()
            )

            await context.bot.send_message(
                partner,
                "💬 Знайдено 😏",
                reply_markup=chat_keyboard_chat()
            )

    # ===== EXIT SEARCH =====
    elif text == "⛔️ Вийти з пошуку":
        if waiting_user == user_id:
            waiting_user = None
            await update.message.reply_text(
                "❌ Пошук скасовано",
                reply_markup=chat_keyboard_main()
            )
        else:
            await update.message.reply_text("Ти не в пошуку 😏")

    # ===== OTHER PARTNER =====
    elif text == "🗿 Інший співрозмовник":
        if user_id in pairs:
            partner = pairs[user_id]

            del pairs[user_id]
            if partner in pairs:
                del pairs[partner]

            await context.bot.send_message(
                partner,
                "🗿 Співрозмовник пішов",
                reply_markup=chat_keyboard_main()
            )

        waiting_user = user_id

        await update.message.reply_text(
            "🔍 новий пошук...",
            reply_markup=chat_keyboard_search()
        )

    # ===== EXIT CHAT =====
    elif text == "⛔️ Вийти з діалогу":
        if user_id in pairs:
            partner = pairs[user_id]

            del pairs[user_id]
            if partner in pairs:
                del pairs[partner]

            await context.bot.send_message(
                partner,
                "⛔️ Співрозмовник вийшов",
                reply_markup=chat_keyboard_main()
            )

        if waiting_user == user_id:
            waiting_user = None

        await update.message.reply_text(
            "Ви вийшли 😌",
            reply_markup=chat_keyboard_main()
        )

    # ===== MESSAGE =====
    elif user_id in pairs:
        await context.bot.send_message(pairs[user_id], text)

# ================= CALLBACKS =================
async def button(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    data = query.data
    user_id_str = str(query.from_user.id)
    user_id_int = query.from_user.id

    if data == "noop":
        await query.answer()

    elif data == "profile_back":
        genres = get_genres()
        keyboard = [
            [InlineKeyboardButton("🔎 Шукати за назвою", switch_inline_query_current_chat="")]
        ]
        keyboard += [[InlineKeyboardButton(g, callback_data=f"genre_{g}")] for g in genres]
        await replace_message(query, "🍥 Обери жанр або шукай:", InlineKeyboardMarkup(keyboard))

    elif data == "profile_show":
        profile_text, profile_markup = build_profile_keyboard(user_id_int)
        await replace_keep_media(query, profile_text, profile_markup)

    elif data == "profile_liked":
        user = ensure_user_profile(user_id_int)
        liked = user.get("liked", [])
        await replace_message(query, "❤️ Подобається:", build_profile_list_keyboard(liked, "Немає лайків"))

    elif data == "profile_disliked":
        user = ensure_user_profile(user_id_int)
        disliked = user.get("disliked", [])
        await replace_message(query, "💔 Не подобається:", build_profile_list_keyboard(disliked, "Немає дизлайків"))

    elif data.startswith("genre_"):
        genre = data.split("_", 1)[1]

        filtered = [
            (i, a) for i, a in enumerate(get_anime_list())
            if genre.lower() in a.get("genre", "").lower()
        ]

        keyboard = [[InlineKeyboardButton(a.get("name", "Без назви"), callback_data=f"anime_{i}")] for i, a in filtered]
        keyboard.append([InlineKeyboardButton("⬅️ Назад", callback_data="genres_back")])

        await replace_message(query, f"Жанр: {genre}", InlineKeyboardMarkup(keyboard))

    elif data == "genres_back":
        genres = get_genres()

        keyboard = [
            [InlineKeyboardButton("🔎 Шукати за назвою", switch_inline_query_current_chat="")]
        ]
        keyboard += [[InlineKeyboardButton(g, callback_data=f"genre_{g}")] for g in genres]

        await replace_message(query, "🍥 Жанри:", InlineKeyboardMarkup(keyboard))

    elif data.startswith("anime_"):
        idx = int(data.split("_")[1])
        text, markup, photo = anime_menu(idx, user_id_int)
        await send_anime_page(query, text, markup, photo, user_id_int)

    elif data.startswith("openanime_"):
        idx = int(data.split("_")[1])
        text, markup, photo = anime_menu(idx, user_id_int)
        await send_anime_page(query, text, markup, photo, user_id_int)

    elif data.startswith("episodes_"):
        idx = int(data.split("_")[1])

        if not await check_subscription(user_id_int, context):
            keyboard = [
                [InlineKeyboardButton("📢 Підписатися", url=f"https://t.me/{CHANNEL_USERNAME.replace('@', '')}")],
                [InlineKeyboardButton("✅ Я підписався", callback_data=f"check_sub_{idx}")],
                [InlineKeyboardButton("⬅️ Назад", callback_data=f"anime_{idx}")]
            ]
            await replace_keep_media(query, "Підпишись 😏", InlineKeyboardMarkup(keyboard))
            return

        anime = get_anime_list()[idx]
        episodes = anime.get("episodes", [])

        keyboard = []
        for ep in episodes:
            title = ep.get("title", "Серія")
            url = ep.get("url", "")
            if url:
                keyboard.append([InlineKeyboardButton(title, url=url)])

        keyboard.append([InlineKeyboardButton("⬅️ Назад", callback_data=f"anime_{idx}")])

        if not episodes:
            await replace_keep_media(query, "🎬 Серії поки нема", InlineKeyboardMarkup(keyboard))
        else:
            await replace_keep_media(query, "🎬 Серії:", InlineKeyboardMarkup(keyboard))

    elif data.startswith("check_sub_"):
        idx = int(data.split("_")[2])

        if not await check_subscription(user_id_int, context):
            await query.answer("Ти не підписаний 😏", show_alert=True)
            return

        anime = get_anime_list()[idx]
        episodes = anime.get("episodes", [])

        keyboard = []
        for ep in episodes:
            title = ep.get("title", "Серія")
            url = ep.get("url", "")
            if url:
                keyboard.append([InlineKeyboardButton(title, url=url)])

        keyboard.append([InlineKeyboardButton("⬅️ Назад", callback_data=f"anime_{idx}")])

        if not episodes:
            await replace_keep_media(query, "🎬 Серії поки нема", InlineKeyboardMarkup(keyboard))
        else:
            await replace_keep_media(query, "🎬 Серії відкриті:", InlineKeyboardMarkup(keyboard))

    elif data.startswith("rate_"):
        idx = int(data.split("_")[1])
        anime = get_anime_list()[idx]
        name = normalize_name(anime.get("name", ""))

        current = db.search((User.anime == name) & (User.user_id == user_id_str))
        current_text = f"\nТвоя оцінка: {current[0]['rating']}⭐️" if current else ""

        keyboard = [[InlineKeyboardButton(f"{i}⭐️", callback_data=f"star_{idx}_{i}") for i in range(1, 6)]]
        keyboard.append([
            InlineKeyboardButton("❤️", callback_data=f"like_{idx}"),
            InlineKeyboardButton("💔", callback_data=f"dislike_{idx}")
        ])
        keyboard.append([InlineKeyboardButton("⬅️ Назад", callback_data=f"anime_{idx}")])

        await replace_keep_media(query, f"Оцініть:{current_text}", InlineKeyboardMarkup(keyboard))

    elif data.startswith("star_"):
        _, idx, stars = data.split("_")
        idx = int(idx)
        stars = int(stars)

        anime = get_anime_list()[idx]
        name = normalize_name(anime.get("name", ""))

        exists = db.search((User.anime == name) & (User.user_id == user_id_str))

        if exists:
            db.update({"rating": stars}, (User.anime == name) & (User.user_id == user_id_str))
        else:
            db.insert({"anime": name, "user_id": user_id_str, "rating": stars})

        text, markup, photo = anime_menu(idx, user_id_int)
        await send_anime_page(query, text, markup, photo, user_id_int)

    elif data.startswith("like_"):
        idx = int(data.split("_")[1])
        anime = get_anime_list()[idx]
        name = normalize_name(anime.get("name", ""))

        add_like(user_id_int, name)
        await query.answer("Додано в ❤️", show_alert=False)

    elif data.startswith("dislike_"):
        idx = int(data.split("_")[1])
        anime = get_anime_list()[idx]
        name = normalize_name(anime.get("name", ""))

        add_dislike(user_id_int, name)
        await query.answer("Додано в 💔", show_alert=False)

# ================= MAIN =================
def main():
    log("Бот активовано")

    app = ApplicationBuilder().token(TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(button))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, chat_logic))
    app.add_handler(InlineQueryHandler(inline_query))

    app.run_polling()

if __name__ == "__main__":
    main()
